# Environment variables for Science Paper Summariser
# Copy this file to .env and fill in your API keys as needed.
#
# API keys are ONLY required when using explicit API providers (e.g. claude-api,
# openai-api) or when the corresponding CLI tool is not installed and the system
# falls back to the API. If you use CLI tools (claude, codex, gemini, copilot),
# no API keys are needed for those providers.

# Anthropic API key (for Claude API fallback / claude-api)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (for openai / openai-api)
OPENAI_API_KEY=your_openai_api_key_here

# Perplexity API key (for perplexity / perplexity-api)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google API key (for Gemini API fallback / gemini-api)
GOOGLE_API_KEY=your_google_api_key_here
