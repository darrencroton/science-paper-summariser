# Environment variables for Science Paper Summariser
# Copy this file to .env and fill in your API keys as needed.
#
# API keys are required when using API mode with the corresponding provider.
# CLI providers (claude, codex, gemini, copilot, opencode) do not use these keys.

# Anthropic API key (api claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key (api openai)
OPENAI_API_KEY=your_openai_api_key_here

# Perplexity API key (api perplexity)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Google API key (api gemini)
GOOGLE_API_KEY=your_google_api_key_here

# openai-compatible base URL (api openai-compatible) — required for that provider.
# Set this to the /v1 endpoint of your local inference server, e.g.:
#   LM Studio:  http://localhost:1234/v1
#   llama.cpp:  http://localhost:8080/v1
#   Ollama:     http://localhost:11434/v1
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1

# Long local generations can exceed the OpenAI SDK's usual request timeout.
# Default for openai-compatible is 3600 seconds; override if your server is
# faster or slower.
OPENAI_COMPATIBLE_TIMEOUT=3600

# openai-compatible authentication is optional. If your server requires a bearer
# token, set OPENAI_COMPATIBLE_API_KEY_ENV to the name of the env var containing
# the key. Prefer storing that key outside this repo, for example in ~/.llm/.env.llm:
#
#   export LOCAL_LLM_API_KEY=your_key_here
#
# Then either source ~/.llm/.env.llm before launching, or use a wrapper script.
OPENAI_COMPATIBLE_API_KEY_ENV=LOCAL_LLM_API_KEY
